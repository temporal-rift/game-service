<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="action-002-create-player-state" author="game-service">
        <createTable tableName="player_state">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="player_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="faction" type="VARCHAR(50)"/>
            <column name="jammed" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="player_state_hand_card">
            <column name="player_state_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_player_state_hand_card_state"
                             referencedTableName="player_state" referencedColumnNames="id"/>
            </column>
            <column name="card_position" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="card_instance_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="card_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="player_state_hand_card"
                       columnNames="player_state_id,card_position"
                       constraintName="pk_player_state_hand_card"/>
        <addUniqueConstraint
                tableName="player_state"
                columnNames="game_id,player_id"
                constraintName="uq_player_state_game_player"/>
    </changeSet>

</databaseChangeLog>
