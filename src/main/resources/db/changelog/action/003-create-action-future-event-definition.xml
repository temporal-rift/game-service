<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="action-003-create-action-future-event-definition" author="game-service">
        <createTable tableName="action_future_event_definition">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="era_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="outcomes" type="JSONB">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="action_future_event_definition"
                columnNames="game_id,era_number,event_id"
                constraintName="uq_action_future_event_game_era_event"/>
        <createIndex
                tableName="action_future_event_definition"
                indexName="idx_action_future_event_game_era_order">
            <column name="game_id"/>
            <column name="era_number"/>
            <column name="display_order"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
