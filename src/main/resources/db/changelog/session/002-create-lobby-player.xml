<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet id="002-create-lobby-player" author="game-service">
    <createTable tableName="lobby_player">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="lobby_id" type="UUID">
        <constraints nullable="false" foreignKeyName="fk_lobby_player_lobby" references="lobby(id)"/>
      </column>
      <column name="player_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="player_name" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="faction" type="TEXT"/>
      <column name="joined_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex tableName="lobby_player" indexName="lobby_player_lobby_id_idx">
      <column name="lobby_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
