<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet id="007-create-game-available-event" author="game-service">
    <createTable tableName="game_available_event_id">
      <column name="game_id" type="UUID">
        <constraints nullable="false" foreignKeyName="fk_game_available_event_game" references="game(id)"/>
      </column>
      <column name="event_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="list_order" type="INT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addPrimaryKey tableName="game_available_event_id" columnNames="game_id, list_order"
        constraintName="pk_game_available_event_id"/>
  </changeSet>

</databaseChangeLog>

