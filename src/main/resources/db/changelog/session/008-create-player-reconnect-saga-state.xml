<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="008-create-player-reconnect-saga-state" author="game-service">
        <createTable tableName="player_reconnect_saga_state">
            <column name="saga_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="player_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="grace_expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="player_reconnect_saga_state" indexName="idx_reconnect_saga_game_player">
            <column name="game_id"/>
            <column name="player_id"/>
        </createIndex>

        <createIndex tableName="player_reconnect_saga_state" indexName="idx_reconnect_saga_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
