<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

  <changeSet id="002-create-processed-events" author="game-service">
    <createTable tableName="processed_events">
      <column name="event_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="consumer" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="processed_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addPrimaryKey
        tableName="processed_events"
        columnNames="event_id, consumer"
        constraintName="pk_processed_events"/>
  </changeSet>

</databaseChangeLog>
