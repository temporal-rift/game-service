<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="scoring-002-create-scoring-context-era-outcome-expectation" author="game-service">
        <createTable tableName="scoring_context_era_outcome_expectation">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="era_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="expected_outcome_count" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="scoring_context_era_outcome_expectation"
                columnNames="game_id,era_number"
                constraintName="uq_scoring_context_era_outcome_expectation_game_era"/>
    </changeSet>

</databaseChangeLog>
