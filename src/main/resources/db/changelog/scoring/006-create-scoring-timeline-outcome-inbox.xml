<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="scoring-006-create-scoring-timeline-outcome-inbox" author="game-service">
        <createTable tableName="scoring_timeline_outcome_inbox">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="era_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="winning_outcome_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="JSONB">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="scoring_timeline_outcome_inbox"
                columnNames="game_id,era_number,event_id"
                constraintName="uq_scoring_timeline_outcome_inbox_game_era_event"/>
    </changeSet>

</databaseChangeLog>
