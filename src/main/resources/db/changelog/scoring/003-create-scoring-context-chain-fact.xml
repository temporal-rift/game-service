<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="scoring-003-create-scoring-context-chain-fact" author="game-service">
        <createTable tableName="scoring_context_chain_fact">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="player_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="chain_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="era_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="consumed" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="scoring_context_chain_fact" indexName="idx_scoring_context_chain_fact_game_consumed">
            <column name="game_id"/>
            <column name="consumed"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
