<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="scoring-005-create-scoring-era-completion" author="game-service">
        <createTable tableName="scoring_era_completion">
            <column name="game_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="era_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                tableName="scoring_era_completion"
                columnNames="game_id,era_number"
                constraintName="pk_scoring_era_completion"/>
    </changeSet>

</databaseChangeLog>
